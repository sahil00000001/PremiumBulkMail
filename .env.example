# Server port (default: 5000 locally, auto-set by Vercel in production)
PORT=5000

# Pixel tracker backend URL — set this to your deployed backend (Pixel-Tracker) Vercel URL
# e.g. https://your-pixel-tracker.vercel.app
PIXEL_TRACKER_BASE_URL=https://pixel-tracker-dc1i.onrender.com

# CORS — set to your frontend domain in production, or leave as * for open access
# CORS_ORIGIN=https://your-frontend-domain.vercel.app

# Optional: PostgreSQL connection string for persistent storage
# If not set, the app uses in-memory storage (data resets on restart)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
